  maxArrowCount: 16
  arrowHeightOffset: 1.05
  labelHeightOffset: 1.55
  arrowScale: 0.45
  arrowBobAmplitude: 0.08
  arrowBobSpeed: 2.8
  anchorRepositionThreshold: 0.35
  behindPlayerDotLimit: -0.2
  arrowPrefab: {fileID: 0}
  labelPrefab: {fileID: 0}
  arrowMaterial: {fileID: 2100000, guid: 99814db9c052fda4abba60d921f87980, type: 2}
  accentMaterial: {fileID: 2100000, guid: d8fbbd4f922f93e4eb328bef17a8cea4, type: 2}
  arrivedPopup: {fileID: 0}
  audioSource: {fileID: 1100103281}
  arrivalClip: {fileID: 0}
  waypoints:
  - locationName: Balcony
    localPosition: {x: 0, y: 0, z: 0}
    reachDistance: 1.5
    description: Starting point of the route. Stand here first so the AR guide can
      establish the tour direction.
  - locationName: Sala
    localPosition: {x: 1.3, y: 0, z: 1.4}
    reachDistance: 1.5
    description: Proceed to the Sala and follow the route as it opens into the main
      receiving area.
  - locationName: Dining
    localPosition: {x: 2.8, y: 0, z: 2.6}
    reachDistance: 1.5
    description: Continue toward the Dining area where the household and ceremonial
      route continues.
  - locationName: Bedroom
    localPosition: {x: 4.2, y: 0, z: 3.8}
    reachDistance: 1.5
    description: Move into the Bedroom stop and keep the arrow centered as the route
      narrows.
  - locationName: Family Room
    localPosition: {x: 5.4, y: 0, z: 5.1}
    reachDistance: 1.5
    description: Follow the guide to the Family Room and stay near the route line
      for the cleanest AR experience.
  - locationName: Secret Areas
    localPosition: {x: 5.5, y: 0, z: 6.8}
    reachDistance: 1.5
    description: Continue to the Secret Areas stop and let the guide lead you through
      the hidden route segment.
  - locationName: War Memorabilia
    localPosition: {x: 4.4, y: 0, z: 8.2}
    reachDistance: 1.5
    description: Turn toward the War Memorabilia stop for the collection-focused
      portion of the tour.
  - locationName: Documents
    localPosition: {x: 2.8, y: 0, z: 9.5}
    reachDistance: 1.5
    description: Proceed to Documents and follow the mini-map as the route bends
      back across the gallery.
  - locationName: Garden
    localPosition: {x: 1.3, y: 0, z: 11}
    reachDistance: 1.5
    description: Final destination. Complete the route at the Garden after reviewing
      the last heritage stop.
